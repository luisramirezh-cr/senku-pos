# Clerk — same key as gosenku.com (satellite)
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_...
CLERK_SECRET_KEY=sk_test_...
NEXT_PUBLIC_CLERK_SIGN_IN_URL=https://gosenku.com/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=https://gosenku.com/sign-up

# senku_pos — own DB (NOT shared with gosenku.com or loyalty)
DATABASE_URL=postgresql://user:pass@localhost:5432/senku_pos

# gosenku.com internal API secret (same value configured on both sides)
INTERNAL_API_SECRET=secret_...

# App
NEXT_PUBLIC_APP_URL=http://localhost:3001
NODE_ENV=development

# Dev mock — set to 'true' to bypass gosenku.com/api/internal when developing locally
# DEV_MOCK_SESSION=true
# DEV_MOCK_BUSINESS_ID=dev-business-001
# DEV_MOCK_BUSINESS_NAME=Mi Negocio Demo
