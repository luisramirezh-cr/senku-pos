{
  "name": "senku-pos",
  "private": true,
  "version": "0.0.1",
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=9.0.0"
  },
  "scripts": {
    "dev": "pnpm --filter @senku/pos dev",
    "build": "pnpm --filter @senku/pos build",
    "typecheck": "pnpm -r typecheck",
    "lint": "eslint . --max-warnings 0",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "db:generate": "pnpm --filter @senku/pos db:generate",
    "db:push": "pnpm --filter @senku/pos db:push",
    "db:migrate": "pnpm --filter @senku/pos db:migrate",
    "db:seed": "pnpm --filter @senku/pos db:seed",
    "db:studio": "pnpm --filter @senku/pos db:studio"
  },
  "devDependencies": {
    "@eslint/js": "^9.17.0",
    "eslint": "^9.17.0",
    "eslint-config-prettier": "^10.0.0",
    "prettier": "^3.4.2",
    "typescript": "^5.7.2",
    "typescript-eslint": "^8.19.0"
  }
}
